<odoo>

    <record id="all_tasks_view_tree" model="ir.ui.view">
        <field name="name">All Tasks Tree</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <tree class="header_custom">
                <field name="task_name"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="status"/>
                <field name="assign_to"/>
            </tree>
        </field>
    </record>

    <record id="all_tasks_view_form" model="ir.ui.view">
        <field name="name">All Tasks Form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button string="Set to New" class="btn-primary" type="object" name="action_new"
                                invisible="status == 'new'"/>
                        <button string="In Progress" class="btn-primary" type="object" name="action_in_progress"
                                invisible="status != 'new'"/>
                        <button string="Completed" class="btn-primary" type="object" name="action_completed"
                                invisible="status != 'in_progress'"/>
                        <field name="status" widget="statusbar" options="{'clickable':1}"/>
                    </header>
                    <group>
                        <group string="GENERAL INFO">
                            <field name="task_name"/>
                            <field name="description"/>
                        </group>
                        <group string="ADDITIONAL INFO">
                            <field name="due_date"/>
                            <field name="status"/>
                            <field name="assign_to"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="all_tasks_view_search" model="ir.ui.view">
        <field name="name">all tasks search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_name"/>
                <field name="assign_to"/>
                <filter name="is_new" string="New Tasks" domain="[('status', '=', 'new')]"/>
                <filter name="in_progress" string="IN Progress Tasks" domain="[('status', '=', 'in_progress')]"/>
                <filter name="completed" string="Completed Tasks" domain="[('status', '=', 'completed')]"/>
                <filter name="group_assign_to" string="Assign To" context="{'group_by': 'assign_to'}"/>
                <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                <filter name="group_due_date" string="Due date" context="{'group_by': 'due_date'}"/>
            </search>
        </field>
    </record>

    <record id="todo_tasks_action" model="ir.actions.act_window">
        <field name="name">To-Do</field>
        <field name="res_model">todo.task</field>
    </record>

    <menuitem
            id="all_tasks_menu"
            name="All Tasks"
            parent="todo_menu"
            action="todo_tasks_action"
    />
</odoo>