<odoo>
    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property Tree</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <tree class="header_custom" decoration-danger="(is_late)">
                <field name="name"/>
                <field name="is_late" invisible="1"/>
                <field name="postcode"/>
                <field name="owner_id"/>
                <field name="date_availability"/>
                <field name="selling_price"/>
                <field name="expected_price"/>
                <field name="garden"/>
                <field name="garden_area"/>
                <field name="expected_selling_date"/>
                <field name="garden_orientation"/>
                <field name="description" optional="1"/>
                <field name="facades" optional="1"/>
                <field name="garage" optional="1"/>
                <field name="state"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="property_view_form" model="ir.ui.view">
        <field name="name">property from</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button string="Set to draft" class="btn-primary" type="object" name="action_draft"
                                invisible="state == 'draft'"/>
                        <button string="Pending" class="btn-secondary" type="object" name="action_pending"
                                invisible="state != 'draft'"/>
                        <button string="Sold" class="btn-success" type="object" name="action_sold"
                                invisible="state != 'pending'"/>
                        <field name="state" widget="statusbar" options="{'clickable':1}"/>
                    </header>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="GENERAL INFO">
                            <field name="date_availability" required="1"/>
                            <field name="postcode"/>
                            <field name="is_late" invisible="1"/>
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                            <field name="different"/>
                            <field name="bedrooms"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                            <field name="active"/>
                        </group>
                        <group string="ADDITIONAL INFO">
                            <field name="owner_id"/>
                            <field name="owner_phone"/>
                            <field name="owner_address"/>
                            <field name="garden_area"/>
                            <field name="garden"/>
                            <field name="expected_selling_date"/>
                            <field name="garden_orientation"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" required="1"/>
                    </group>

                    <notebook>
                        <page string="Bedrooms">
                            <field name="bedroom_line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="area"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Garden">
                            <field name="garden_line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="area"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>
                <filter name="is_garden" string="With garden" domain="[('garden', '=', True)]"/>
                <filter name="is_not_garage" string="Without garage" domain="[('garage', '=', False)]"/>
                <filter name="group_garden" string="Garden" context="{'group_by': 'garden'}"/>
            </search>
        </field>
    </record>


    <record id="property_action" model="ir.actions.act_window">
        <field name="name">Property</field>
        <field name="res_model">property</field>
    </record>

    <record id="property_closed_action_server" model="ir.actions.server">
        <field name="name"> closed </field>
        <field name="model_id" ref="model_property"/>
<!--        This for put the colsed withe list (Actions)-->
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>

    <record id ="check_selling_date_cron" model="ir.cron">
<!--the best way to named action (cron) or automated action is name of model after that what does do -->
        <field name="name">Property: check selling date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
<!--        -1 mean unlemted -->
        <field name="numbercall">-1</field>
    </record>

    <menuitem
            id="property_menu"
            name="Properties"
            parent="properties_menu"
            action="property_action"
    />
</odoo>
